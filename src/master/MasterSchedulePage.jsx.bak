
import {useMaster} from "./MasterContext"

function slots(){

const arr=[]
let h=7
let m=0

for(let i=0;i<56;i++){

arr.push((h<10?"0"+h:h)+":"+(m<10?"0"+m:m))

m+=15

if(m>=60){
h++
m=0
}

}

return arr

}

export default function MasterSchedulePage(){

const {bookings}=useMaster()

const s=slots()

return(

<div>

<h3>Расписание</h3>

{s.map(t=>{

const b=bookings.find(x=>new Date(x.start_at).toLocaleTimeString("ru-RU",{hour:"2-digit",minute:"2-digit"})===t)

return(

<div key={t} style={{
border:"1px solid #ddd",
padding:"10px",
marginBottom:"6px",
borderRadius:"8px"
}}>

<b>{t}</b>

{b?

<span style={{marginLeft:"10px"}}>
{b.client_name||"клиент"} ({b.status})
</span>

:

<span style={{marginLeft:"10px",color:"#aaa"}}>
свободно
</span>

}

</div>

)

})}

</div>

)

}
