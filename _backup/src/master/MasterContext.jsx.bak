
import {createContext,useContext,useEffect,useState} from "react"
import {getMasterMetrics} from "../api/master"
import {getSalonBookings,getSalonClients} from "../api/salon"

const MasterContext=createContext()

export function MasterProvider({children}){

const slug=window.MASTER_SLUG

const [metrics,setMetrics]=useState(null)
const [bookings,setBookings]=useState([])
const [clients,setClients]=useState([])
const [loading,setLoading]=useState(true)

async function load(){

try{

const m=await getMasterMetrics(slug)
setMetrics(m.metrics||m)

const b=await getSalonBookings(window.SALON_SLUG)
setBookings((b.bookings||[]).filter(x=>x.master_name===window.MASTER_NAME||true))

const c=await getSalonClients(window.SALON_SLUG)
setClients(c.clients||[])

}catch(e){

console.error("MASTER LOAD ERROR",e)

}

setLoading(false)

}

useEffect(()=>{load()},[])

return(

<MasterContext.Provider value={{
metrics,
bookings,
clients,
loading,
reload:load
}}>

{children}

</MasterContext.Provider>

)

}

export function useMaster(){
return useContext(MasterContext)
}
